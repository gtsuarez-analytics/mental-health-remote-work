# ================================================================================
# VARIABLES DE ENTORNO — SALUD MENTAL TRABAJO REMOTO
# ================================================================================
# Plantilla pública. Copiar a .env y completar con credenciales reales.
# ================================================================================

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mental_health_db
DB_USER=tu_usuario
DB_PASSWORD=tu_password

# pgAdmin (interfaz web opcional)
PGADMIN_EMAIL=tu_email@example.com
PGADMIN_PASSWORD=tu_password_pgadmin

# Rutas de datos
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_EXPORTS_PATH=data/exports

# Configuración de logging
LOG_LEVEL=INFO
LOG_PATH=logs
